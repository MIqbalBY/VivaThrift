{
  "name": "vivathrift",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "typecheck": "nuxt typecheck",
    "postinstall": "nuxt prepare",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1025.0",
    "@aws-sdk/s3-request-presigner": "^3.1025.0",
    "@nuxt/fonts": "^0.14.0",
    "@nuxt/image": "^2.0.0",
    "@nuxtjs/i18n": "^10.2.4",
    "@nuxtjs/robots": "^6.0.6",
    "@nuxtjs/sitemap": "^8.0.11",
    "@nuxtjs/supabase": "^2.0.4",
    "@sentry/nuxt": "^10.48.0",
    "@supabase/supabase-js": "^2.76.1",
    "@tailwindcss/vite": "4.2.2",
    "@types/leaflet": "^1.9.21",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "browser-image-compression": "^2.0.2",
    "leaflet": "^1.9.4",
    "lucide-vue-next": "^1.0.0",
    "nuxt": "^4.4.2",
    "tailwindcss": "^4.2.2",
    "vue": "^3.5.32",
    "vue-advanced-cropper": "^2.8.9",
    "vue-router": "^5.0.4",
    "web-push": "^3.6.7"
  },
  "pnpm": {
    "overrides": {
      "@vercel/nft": "^0.27.4"
    },
    "peerDependencyRules": {
      "allowedVersions": {
        "@vercel/analytics>vue-router": "^5",
        "@vercel/speed-insights>vue-router": "^5"
      }
    },
    "ignoredBuiltDependencies": [
      "@parcel/watcher",
      "@sentry/cli",
      "esbuild",
      "sharp",
      "vue-demi"
    ]
  },
  "devDependencies": {
    "@types/web-push": "^3.6.4",
    "@vue/language-core": "^3.2.6",
    "vitest": "^4.1.4"
  }
}