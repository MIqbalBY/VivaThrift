# ─────────────────────────────────────────────────────────────────────────────
# Supabase
# ─────────────────────────────────────────────────────────────────────────────
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_KEY=<anon-key>
SUPABASE_SECRET_KEY=<service-role-jwt>

# ─────────────────────────────────────────────────────────────────────────────
# Cloudflare R2
# Get values from: Cloudflare Dashboard → R2 → API Tokens
# ─────────────────────────────────────────────────────────────────────────────
R2_ACCOUNT_ID=<your-cloudflare-account-id>
R2_ACCESS_KEY_ID=<r2-api-token-access-key>
R2_SECRET_ACCESS_KEY=<r2-api-token-secret>
R2_BUCKET_NAME=vivathrift-media
# S3-compatible endpoint: https://<ACCOUNT_ID>.r2.cloudflarestorage.com
R2_ENDPOINT=https://<your-account-id>.r2.cloudflarestorage.com
# Public CDN URL (custom domain or R2 public URL):
R2_PUBLIC_URL=https://cdn.vivathrift.store

# ─────────────────────────────────────────────────────────────────────────────
# Sentry (Error Tracking)
# Get DSN: sentry.io → Project → Settings → Client Keys (DSN)
# Get Auth Token: sentry.io → Settings → Auth Tokens
# ─────────────────────────────────────────────────────────────────────────────
SENTRY_DSN=https://<key>@o<org-id>.ingest.sentry.io/<project-id>
VITE_SENTRY_DSN=https://<key>@o<org-id>.ingest.sentry.io/<project-id>
SENTRY_ORG=<your-sentry-org-slug>
SENTRY_PROJECT=vivathrift
SENTRY_AUTH_TOKEN=<auth-token-for-source-maps-upload>

# ─────────────────────────────────────────────────────────────────────────────
# Web Push (VAPID)
# Generate keys: node -e "const wp=require('web-push'); console.log(wp.generateVAPIDKeys())"
# ─────────────────────────────────────────────────────────────────────────────
VAPID_PUBLIC_KEY=<base64url-public-key>
VAPID_PRIVATE_KEY=<base64url-private-key>
VAPID_SUBJECT=mailto:admin@vivathrift.store

# ─────────────────────────────────────────────────────────────────────────────
# Midtrans / Xendit / Biteship / etc.
# ─────────────────────────────────────────────────────────────────────────────
SITE_URL=http://localhost:3004
RESEND_API_KEY=<resend-api-key>
XENDIT_KEY=<xendit-secret-key>
XENDIT_SECRET_KEY=<optional-alias-of-xendit-key>
XENDIT_CALLBACK_TOKEN=<xendit-callback-token>
XENDIT_WEBHOOK_TOKEN=<optional-alias-of-callback-token>
# Buyer-borne gateway fee formula for checkout total:
# fee = round(base_amount * percent / 100) + flat
# base_amount = subtotal + shipping + platform_fee
XENDIT_PAYMENT_FEE_PERCENT=0
XENDIT_PAYMENT_FEE_FLAT=0
# Optional per-channel override (JSON, lowercase keys):
# {"qris":{"percent":0.7,"flat":0},"bca_va":{"percent":0,"flat":4000},"gopay":{"percent":1.5,"flat":0}}
XENDIT_PAYMENT_FEE_BY_CHANNEL_JSON={"qris":{"percent":0.63,"flat":0},"bca_va":{"percent":0,"flat":4000},"bni_va":{"percent":0,"flat":4000},"bri_va":{"percent":0,"flat":4000},"mandiri_va":{"percent":0,"flat":4000},"gopay":{"percent":5,"flat":0},"ovo":{"percent":1.5,"flat":0},"dana":{"percent":1.5,"flat":0},"shopeepay":{"percent":1.8018,"flat":0}}
# Tax percent applied on gateway fee base (Xendit fee tax)
XENDIT_PAYMENT_FEE_TAX_PERCENT=11
# Disbursement fee charged to buyer so platform margin stays net
XENDIT_DISBURSEMENT_FEE_SELLER_FLAT=2500
XENDIT_DISBURSEMENT_FEE_ADMIN_FLAT=2500
# Optional: set true/1/yes/on to auto-disburse platform fee to admin bank.
# Default is OFF (platform fee stays in Xendit balance for manual withdrawal).
XENDIT_AUTO_DISBURSE_ADMIN_FEE=false
# Admin bank account for platform fee disbursement (used when auto-disburse ON).
# Defaults to Bank Jago if not set.
ADMIN_BANK_CODE=BANK_JAGO
ADMIN_BANK_ACCOUNT_NUMBER=103438588617
ADMIN_BANK_ACCOUNT_NAME=Muhammad Iqbal Baiduri Yamani
BITESHIP_KEY=<biteship-api-key>
# Optional webhook auth if enabled in Biteship dashboard webhook settings.
# Use either a shared token OR HTTP Basic Auth.
BITESHIP_WEBHOOK_TOKEN=<optional-webhook-token>
BITESHIP_WEBHOOK_BASIC_USER=<optional-basic-auth-username>
BITESHIP_WEBHOOK_BASIC_PASSWORD=<optional-basic-auth-password>
# Optional persistent global rate limit backend (recommended for production serverless).
UPSTASH_REDIS_REST_URL=https://<your-upstash-endpoint>.upstash.io
UPSTASH_REDIS_REST_TOKEN=<upstash-rest-token>
